# ai-squad tool repo — root .gitignore

# CLI runtime state (jingle flag + last-used options)
.ai-squad.json

# Node
node_modules/
npm-debug.log*

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Editor artefacts
.idea/
.vscode/
*.swp
*.swo
*~

# Test artefacts
/tmp/

# Claude Code local settings (generated at runtime, not template content)
# Leading / anchors to repo root so template/.claude/settings.local.json is unaffected
/.claude/settings.local.json
var/*

# Swarm v2 session data (worktrees, status files, result.md)
.swarm/squad
maple
.maple.json
